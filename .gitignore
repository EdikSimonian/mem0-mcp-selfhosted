# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# pytest / ruff
.pytest_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment files (no leading slash → matches at any depth, e.g. setup/.env)
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Credentials
.credentials.json

# MCP config (contains personal IPs, API keys)
.mcp.json

# Benchmark output
benchmarks/*results*.json

# Local development tooling
.claude/
openspec/
docs/

# Compose stack runtime data lives outside the repo (MEM0_DATA_DIR points at
# ~/.mem0-stack by default). These globs catch accidental in-tree copies.
setup/volumes/
setup/backups/
volumes/
backups/
