# Copy to .env and adjust. .env is gitignored.

# --- Data directory ---
# Where Qdrant + Neo4j persist their data. Must be an ABSOLUTE path —
# Docker Compose does not expand `~` or `$HOME` in volume paths.
# Recommended: a directory outside the repo so the data survives clones,
# moves, and `git clean`. Example: /Users/<you>/.mem0-stack
MEM0_DATA_DIR=

# --- Qdrant ---
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Neo4j ---
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
# Default is the upstream community-edition default. Change before exposing
# Neo4j on anything other than localhost.
NEO4J_PASSWORD=mem0graph
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G
